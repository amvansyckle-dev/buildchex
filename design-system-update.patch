-import Anthropic from "@anthropic-ai/sdk";
-
-const anthropic = new Anthropic({
-  apiKey: process.env.ANTHROPIC_API_KEY,
-});
-
-interface AIProcessingResult {
-  processedText: string;
-  signals: {
-    sentiment: "positive" | "neutral" | "negative";
-    confidence: number;
-    flags: string[];
-    issuesDetected: string[];
-    keyThemes: string[];
-  };
-  moderationFlags: string[];
-}
-
-const SYSTEM_PROMPT = `You are a review processing AI for BuildChex, a homeowner review platform for residential builders and contractors in New Jersey.
-
-Your job is to take a raw homeowner review and:
-
-1. REWRITE it in neutral, third-person language (e.g., "The homeowner reported..." not "I had...")
-2. STRIP any personally identifying information (names, addresses, phone numbers, emails, specific dates)
-3. KEEP all factual claims about the work (delays, cost overruns, quality issues, positive experiences)
-4. EXTRACT signals from the review
-
-Rules for rewriting:
-- Convert first-person to third-person
-- Remove emotional language but preserve the factual substance
-- Keep specific details (dollar amounts as ranges, timeframes, project types)
-- Remove any profanity or hostile language
-- If the reviewer names specific people, replace with role titles (e.g., "the project manager")
-- Maintain the overall sentiment (don't make a negative review sound positive or vice versa)
-
-Respond in this exact JSON format:
-{
-  "processedText": "The rewritten review text in third-person neutral language",
-  "signals": {
-    "sentiment": "positive" | "neutral" | "negative",
-    "confidence": 0.0-1.0,
-    "flags": ["list of any content flags like 'potential_defamation', 'pii_detected', 'spam_likely', 'review_too_vague'"],
-    "issuesDetected": ["list of specific issues mentioned like 'missed_deadlines', 'cost_overruns', 'poor_communication'"],
-    "keyThemes": ["list of 2-4 key themes from the review"]
-  },
-  "moderationFlags": ["list of flags that need human moderator attention, empty if none"]
-}`;
-
-export async function processReview(
-  rawText: string,
-  positiveText: string | null,
-  projectType: string,
-  rating: number
-): Promise<AIProcessingResult> {
-  const userPrompt = `Process this homeowner review:
-
-Project Type: ${projectType}
-Overall Rating: ${rating}/5
-
-Main Review:
-${rawText}
-
-${positiveText ? `Positive Highlights:\n${positiveText}` : ""}
-
-Return ONLY valid JSON, no other text.`;
-
-  try {
-    const message = await anthropic.messages.create({
-      model: "claude-sonnet-4-20250514",
-      max_tokens: 1024,
-      messages: [
-        {
-          role: "user",
-          content: userPrompt,
-        },
-      ],
-      system: SYSTEM_PROMPT,
-    });
-
-    const responseText =
-      message.content[0].type === "text" ? message.content[0].text : "";
-
-    // Parse the JSON response
-    const parsed = JSON.parse(responseText);
-
-    return {
-      processedText: parsed.processedText,
-      signals: {
-        sentiment: parsed.signals.sentiment,
-        confidence: parsed.signals.confidence,
-        flags: parsed.signals.flags || [],
-        issuesDetected: parsed.signals.issuesDetected || [],
-        keyThemes: parsed.signals.keyThemes || [],
-      },
-      moderationFlags: parsed.moderationFlags || [],
-    };
-  } catch (error) {
-    console.error("Claude API error:", error);
-
-    // Return a safe fallback — the review still gets saved, just without AI processing
-    return {
-      processedText: "",
-      signals: {
-        sentiment: "neutral",
-        confidence: 0,
-        flags: ["ai_processing_failed"],
-        issuesDetected: [],
-        keyThemes: [],
-      },
-      moderationFlags: ["ai_processing_failed_needs_manual_review"],
-    };
-  }
-}
