--- BuildChex Database Schema
--- Run this in the Supabase SQL Editor
-
--- ============================================
--- BUILDERS TABLE
--- ============================================
-CREATE TABLE builders (
-  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
-  name TEXT NOT NULL,
-  llc_name TEXT,
-  slug TEXT UNIQUE NOT NULL,
-  counties TEXT[] DEFAULT '{}',
-  project_types TEXT[] DEFAULT '{}',
-  nj_registration_number TEXT,
-  is_claimed BOOLEAN DEFAULT false,
-  created_at TIMESTAMPTZ DEFAULT now(),
-  updated_at TIMESTAMPTZ DEFAULT now()
-);
-
-CREATE INDEX idx_builders_slug ON builders(slug);
-CREATE INDEX idx_builders_name_search ON builders USING gin(to_tsvector('english', name || ' ' || COALESCE(llc_name, '')));
-
--- ============================================
--- REVIEWS TABLE
--- ============================================
-CREATE TABLE reviews (
-  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
-  builder_id UUID REFERENCES builders(id) NOT NULL,
-
-  -- Structured fields (from form)
-  project_type TEXT NOT NULL,
-  county TEXT NOT NULL,
-  cost_range TEXT NOT NULL,
-  project_year TEXT,
-  timeline_vs_estimate TEXT NOT NULL,
-  cost_vs_quote TEXT NOT NULL,
-  issues TEXT[] DEFAULT '{}',
-  overall_rating INTEGER CHECK (overall_rating BETWEEN 1 AND 5) NOT NULL,
-  would_hire_again TEXT CHECK (would_hire_again IN ('yes', 'no', 'not_sure')) NOT NULL,
-
-  -- Text content
-  raw_text TEXT NOT NULL,
-  raw_positive_text TEXT,
-  processed_text TEXT,
-
-  -- AI processing
-  ai_signals JSONB DEFAULT '{}',
-  ai_flags TEXT[] DEFAULT '{}',
-
-  -- Moderation
-  status TEXT DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'ready_for_review', 'approved', 'rejected')),
-  moderation_notes TEXT,
-  moderated_by TEXT,
-  moderated_at TIMESTAMPTZ,
-
-  -- Metadata
-  submitted_at TIMESTAMPTZ DEFAULT now(),
-  published_at TIMESTAMPTZ,
-
-  -- Spam prevention
-  submission_fingerprint TEXT
-);
-
-CREATE INDEX idx_reviews_builder ON reviews(builder_id);
-CREATE INDEX idx_reviews_status ON reviews(status);
-
--- ============================================
--- BUILDER AGGREGATES TABLE
--- ============================================
-CREATE TABLE builder_aggregates (
-  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
-  builder_id UUID REFERENCES builders(id) UNIQUE NOT NULL,
-
-  avg_rating NUMERIC(3,2),
-  review_count INTEGER DEFAULT 0,
-  would_hire_again_pct NUMERIC(5,2),
-
-  -- Structured signal aggregates
-  delay_reported_pct NUMERIC(5,2),
-  cost_overrun_reported_pct NUMERIC(5,2),
-  top_issues JSONB DEFAULT '[]',
-  signal_averages JSONB DEFAULT '{}',
-
-  updated_at TIMESTAMPTZ DEFAULT now()
-);
-
--- Function to recalculate aggregates when a review is approved
-CREATE OR REPLACE FUNCTION update_builder_aggregates(p_builder_id UUID)
-RETURNS void AS $$
-BEGIN
-  INSERT INTO builder_aggregates (builder_id, avg_rating, review_count, would_hire_again_pct, delay_reported_pct, cost_overrun_reported_pct, updated_at)
-  SELECT
-    p_builder_id,
-    AVG(overall_rating),
-    COUNT(*),
-    ROUND(100.0 * COUNT(*) FILTER (WHERE would_hire_again = 'yes') / NULLIF(COUNT(*), 0), 2),
-    ROUND(100.0 * COUNT(*) FILTER (WHERE timeline_vs_estimate != 'on_time') / NULLIF(COUNT(*), 0), 2),
-    ROUND(100.0 * COUNT(*) FILTER (WHERE cost_vs_quote != 'on_budget') / NULLIF(COUNT(*), 0), 2),
-    now()
-  FROM reviews
-  WHERE builder_id = p_builder_id AND status = 'approved'
-  ON CONFLICT (builder_id) DO UPDATE SET
-    avg_rating = EXCLUDED.avg_rating,
-    review_count = EXCLUDED.review_count,
-    would_hire_again_pct = EXCLUDED.would_hire_again_pct,
-    delay_reported_pct = EXCLUDED.delay_reported_pct,
-    cost_overrun_reported_pct = EXCLUDED.cost_overrun_reported_pct,
-    updated_at = EXCLUDED.updated_at;
-END;
-$$ LANGUAGE plpgsql;
-
--- ============================================
--- BUILDER REQUESTS TABLE
--- ============================================
-CREATE TABLE builder_requests (
-  id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
-  builder_name TEXT NOT NULL,
-  county TEXT,
-  created_at TIMESTAMPTZ DEFAULT now()
-);
-
--- ============================================
--- ROW LEVEL SECURITY (RLS)
--- ============================================
-
--- Enable RLS on all tables
-ALTER TABLE builders ENABLE ROW LEVEL SECURITY;
-ALTER TABLE reviews ENABLE ROW LEVEL SECURITY;
-ALTER TABLE builder_aggregates ENABLE ROW LEVEL SECURITY;
-ALTER TABLE builder_requests ENABLE ROW LEVEL SECURITY;
-
--- Public read access for builders and aggregates
-CREATE POLICY "Builders are viewable by everyone" ON builders
-  FOR SELECT USING (true);
-
-CREATE POLICY "Builder aggregates are viewable by everyone" ON builder_aggregates
-  FOR SELECT USING (true);
-
--- Public read access for approved reviews only
-CREATE POLICY "Approved reviews are viewable by everyone" ON reviews
-  FOR SELECT USING (status = 'approved');
-
--- Allow anonymous inserts for reviews and builder requests
-CREATE POLICY "Anyone can submit a review" ON reviews
-  FOR INSERT WITH CHECK (true);
-
-CREATE POLICY "Anyone can request a builder" ON builder_requests
